# Agentic Alpha Lab — Environment Variables
# Copy to .env and fill in your values

# ══════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/quant_researcher
# Leave blank for SQLite fallback (dev only)

# ══════════════════════════════════════════════════════════════
# AUTHENTICATION
# ══════════════════════════════════════════════════════════════
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

# ══════════════════════════════════════════════════════════════
# CORS (comma-separated)
# ══════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000

# ══════════════════════════════════════════════════════════════
# DOCKER (for docker-compose.prod.yml)
# ══════════════════════════════════════════════════════════════
POSTGRES_PASSWORD=CHANGE_ME
NEXT_PUBLIC_API_URL=http://localhost:8100
NEXT_PUBLIC_WS_URL=ws://localhost:8100/ws

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ══════════════════════════════════════════════════════════════
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
QR_DEFAULT_MODEL=gpt-5-mini

# ══════════════════════════════════════════════════════════════
# OPTIONAL
# ══════════════════════════════════════════════════════════════
FRED_API_KEY=
QR_LOG_LEVEL=INFO
RATE_LIMIT_GENERAL=120
RATE_LIMIT_AUTH=10
