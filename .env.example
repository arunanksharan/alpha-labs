# Quant Researcher — Environment Variables
# Copy to .env and fill in your values

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS (at least one required for AI-powered research)
# ══════════════════════════════════════════════════════════════

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (Llama, fast inference) — https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Default model (alias or full litellm model string)
# Options: claude-sonnet, gpt-4o, gemini-flash, llama-70b, deepseek
QR_DEFAULT_MODEL=claude-sonnet

# ══════════════════════════════════════════════════════════════
# FINANCIAL DATA (optional — platform works without these)
# ══════════════════════════════════════════════════════════════

# FRED (Federal Reserve Economic Data) — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage — free at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io — free tier at https://polygon.io/
POLYGON_API_KEY=

# Tiingo — free at https://www.tiingo.com/
TIINGO_API_KEY=

# Financial Modeling Prep — free at https://financialmodelingprep.com/
FMP_API_KEY=

# News API — free at https://newsapi.org/
NEWSAPI_KEY=

# ══════════════════════════════════════════════════════════════
# SYSTEM
# ══════════════════════════════════════════════════════════════

QR_LOG_LEVEL=INFO
