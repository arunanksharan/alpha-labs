# Quant Researcher — Environment Variables
# Copy to .env and fill in your values

# FRED (Federal Reserve Economic Data) — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: Alpha Vantage — free at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Optional: Polygon.io — free tier at https://polygon.io/
POLYGON_API_KEY=

# Optional: Tiingo — free at https://www.tiingo.com/
TIINGO_API_KEY=

# Optional: Financial Modeling Prep — free at https://financialmodelingprep.com/
FMP_API_KEY=

# Optional: News API — free at https://newsapi.org/
NEWSAPI_KEY=

# Logging
QR_LOG_LEVEL=INFO
